{
  "name": "netlab",
  "version": "0.1.0",
  "description": "Browser-based network visualization library with OSI layer simulation",
  "main": "dist/netlab.cjs.js",
  "module": "dist/netlab.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/netlab.es.js",
      "require": "./dist/netlab.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./layers/l1-physical": {
      "import": "./dist/layers/l1-physical/index.js",
      "require": "./dist/layers/l1-physical/index.cjs.js"
    },
    "./layers/l2-datalink": {
      "import": "./dist/layers/l2-datalink/index.js",
      "require": "./dist/layers/l2-datalink/index.cjs.js"
    },
    "./layers/l3-network": {
      "import": "./dist/layers/l3-network/index.js",
      "require": "./dist/layers/l3-network/index.cjs.js"
    },
    "./layers/l4-transport": {
      "import": "./dist/layers/l4-transport/index.js",
      "require": "./dist/layers/l4-transport/index.cjs.js"
    },
    "./layers/l7-application": {
      "import": "./dist/layers/l7-application/index.js",
      "require": "./dist/layers/l7-application/index.cjs.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "coverage": "vitest run --coverage",
    "size": "npm run build && size-limit",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "plan:index": "node scripts/build-plan-index.mjs",
    "plan:index:check": "node scripts/build-plan-index.mjs --check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "@xyflow/react": ">=12.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@xyflow/react": "^12.10.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^3.23.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.14.0",
    "size-limit": "^12.1.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.7",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "zustand": "^5.0.0"
  },
  "keywords": [
    "network",
    "visualization",
    "osi",
    "react-flow",
    "simulation",
    "packet"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/koseki2580/netlab"
  }
}
